# Cấu hình email thông báo
# Copy file này thành .env và điền thông tin thật

# Gmail của bạn (người gửi)
NOTIFY_EMAIL_SENDER=your_gmail@gmail.com

# Gmail App Password (không phải mật khẩu thường)
# Tạo tại: https://myaccount.google.com/apppasswords
# (Cần bật 2-Step Verification trước)
NOTIFY_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Danh sách email nhận, cách nhau bằng dấu phẩy
NOTIFY_EMAIL_TO=recipient1@gmail.com,recipient2@gmail.com
